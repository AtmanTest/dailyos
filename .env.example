# ============================================================================
# DailyOS — Environment Configuration
# ============================================================================
# Copy this template to .env and fill in your values.
#   cp .env.example .env
#
# IMPORTANT: Never commit the real .env file. It is in .gitignore.
# ============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL (e.g., https://your-project-id.supabase.co)
SUPABASE_URL=

# Anon key (public, safe in frontend — RLS protects the data)
SUPABASE_ANON_KEY=

# Service role key (SECRET — backend only, never in frontend)
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM / AI ──────────────────────────────────────────────────────────────
# Used by automation scripts for generating summaries and reviews.
# Supports OpenAI-compatible APIs.

# Base URL (default: https://api.openai.com/v1)
LLM_BASE_URL=

# API key (e.g., sk-... for OpenAI)
LLM_API_KEY=

# Model name (e.g., gpt-4o, gpt-4o-mini, claude-sonnet-4-20250514)
LLM_MODEL=

# ── Application ───────────────────────────────────────────────────────────
APP_TIMEZONE=Europe/Paris

# ── Telegram Bot ──────────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Webhook secret shared between adapter and endpoint
TELEGRAM_WEBHOOK_SECRET=

# ── Apple Shortcuts ───────────────────────────────────────────────────────
# Webhook secret for the /api/webhook/capture endpoint
SHORTCUT_WEBHOOK_SECRET=
